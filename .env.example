# HTTP port for this Express server
PORT=3000

# Local LLM (axllm serve / Qwen on AX8850) — OpenAI-compatible endpoint.
# Point this at the Raspberry Pi 5 running `axllm serve`.
LLM_BASE_URL=http://localhost:8000/v1
LLM_API_KEY=not-needed
LLM_MODEL=AXERA-TECH/Qwen3-1.7B
# Pico (kd1-controller) の HTTP API ベースURL。
# 実機のIPが固まっていないため暫定値。後で実際のPicoアドレスに変更する。
PICO_BASE_URL=http://10.20.10.50
